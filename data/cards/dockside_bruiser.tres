value = 1

[sub_resource type="Resource" id="2_last_breath"]
script = ExtResource("2_card_effect")
trigger = &"last_breath"
action = &"draw_cards"
target_mode = &"self_owner"
value = 1

[resource]
script = ExtResource("1_card_definition")
id = &"dockside_bruiser"
