[gd_resource type="Resource" script_class="CardDefinition" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/card_game/data/card_definition.gd" id="1_card_definition"]
[ext_resource type="Script" path="res://scripts/card_game/data/card_effect.gd" id="2_card_effect"]

[sub_resource type="Resource" id="1_battlecry"]
script = ExtResource("2_card_effect")
trigger = &"battlecry"
action = &"heal_life"
